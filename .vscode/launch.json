{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "PromoRadar.Web (HTTPS)",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/PromoRadar.Web/bin/Debug/net9.0/PromoRadar.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/PromoRadar.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7084;http://localhost:5155"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    },
    {
      "name": "PromoRadar.Web (HTTP)",
      "type": "coreclr",
      "request": "launch",
      "program": "${workspaceFolder}/PromoRadar.Web/bin/Debug/net9.0/PromoRadar.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/PromoRadar.Web",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5155"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}