@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Recuperar senha";
}

<div class="auth-card">
    <h2>Recuperar senha</h2>
    <p class="subtitle">Informe seu e-mail para gerar um link de redefinição.</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
            <label asp-for="Input.Email"></label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Gerar link</button>

        <div class="auth-links">
            <a asp-page="./Login">Voltar para login</a>
        </div>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="auth-status info">@Model.StatusMessage</div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
