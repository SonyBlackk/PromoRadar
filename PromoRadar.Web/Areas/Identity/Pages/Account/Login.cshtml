@page
@model LoginModel
@{
    ViewData["Title"] = "Entrar";
}

<div class="auth-card">
    <h2>Entrar</h2>
    <p class="subtitle">Acesse seu radar de promoções e acompanhe o mercado em tempo real.</p>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
            <label asp-for="Input.Email"></label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="senha" />
            <label asp-for="Input.Password"></label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="Input.RememberMe" class="form-check-input" />
            <label asp-for="Input.RememberMe" class="form-check-label"></label>
        </div>

        <button type="submit" class="btn btn-primary">Entrar no Promo Radar</button>

        <div class="auth-links">
            <a asp-page="./ForgotPassword">Esqueceu a senha?</a>
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Criar conta</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
