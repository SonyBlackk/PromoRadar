<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Promo Radar</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <main class="auth-shell">
        <section class="auth-brand-panel">
            <div class="auth-brand-box">
                <div class="auth-logo">
                    <i class="bi bi-bullseye"></i>
                </div>
                <h1>Promo <span>Radar</span></h1>
                <p>Monitore preços de peças de PC e receba alertas no momento ideal de compra.</p>
                <ul>
                    <li><i class="bi bi-check2-circle"></i> Dashboard premium com histórico inteligente</li>
                    <li><i class="bi bi-check2-circle"></i> Alertas em tempo real por meta de preço</li>
                    <li><i class="bi bi-check2-circle"></i> Análise de oportunidades por loja</li>
                </ul>
            </div>
        </section>

        <section class="auth-form-panel">
            @RenderBody()
        </section>
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
